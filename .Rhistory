observeEvent(input$file, {
req(input$file)
is_loading(TRUE)
waiter_show(
html = tagList(
spin_fading_circles(),
tags$div(
style = "margin-top: 18px; font-size: 18px; color: #78aee0; font-weight: 600;",
"Завантажуємо та обробляємо дані..."
)
),
color = "rgba(242, 235, 227, 0.92)"
)
session$onFlushed(function() {
tryCatch({
df <- read_input_data(input$file$datapath)
required_cols <- c("client_id", "transaction_id", "transaction_date", "product_name", "Бренд")
missing_cols <- setdiff(required_cols, names(df))
if (length(missing_cols) > 0) {
showNotification(
paste("У файлі не вистачає колонок:", paste(missing_cols, collapse = ", ")),
type = "error",
duration = 8
)
}
loaded_data(df)
}, error = function(e) {
loaded_data(NULL)
showNotification(
paste("Помилка завантаження:", e$message),
type = "error",
duration = 8
)
}, finally = {
is_loading(FALSE)
waiter_hide()
})
}, once = TRUE)
})
observeEvent(
list(
input$node_mode,
input$basket_mode,
input$min_days,
input$max_days,
input$journey_depth,
input$journey_top_n,
input$journey_min_clients,
input$journey_label_chars,
input$cohort_depth,
input$cohort_top_n,
input$cohort_min_clients,
input$cohort_label_chars,
input$sankey_start_node,
input$cohort_sankey_start_node
),
{
req(cleaned_data())
show_global_loader("Оновлюємо розрахунки...")
session$onFlushed(function() {
later::later(function() {
hide_global_loader()
}, delay = 0.15)
}, once = TRUE)
},
ignoreInit = TRUE
)
